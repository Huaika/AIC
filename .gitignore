# Secrets
.cdsapirc
**/.cdsapirc

# Large generated/downloaded data
graphcast/data/
*.nc
*.grib
*.grib2
*.idx
*.npz

# Runtime outputs
logs/
graphcast/results/
wget-log

# Backup of the embedded GraphCast clone metadata if vendoring source files.
graphcast/source.git-backup/

# Python caches
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Local virtualenv (created by neural_gcm/setup_env.sh)
.venv/

# Local editor / agent config
.claude/

# NeuralGCM daily-rollout scheduler runtime artifacts (not source/data)
neural_gcm/results_daily/*.log
neural_gcm/results_daily/.done_*
neural_gcm/results_daily/orchestrator.log
