{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "runArgs": ["--gpus", "all", "--restart=unless-stopped"],
  // "runArgs": ["--gpus", "device=1", "--restart=unless-stopped"],
  "shutdownAction": "none",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },
  "mounts": [
    "source=/home/luca/.claude,target=/home/vscode/.claude,type=bind",
    "source=/home/luca/.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.claude && pip install --user -r neural_gcm/requirements.txt",
  "remoteUser": "vscode"
}
